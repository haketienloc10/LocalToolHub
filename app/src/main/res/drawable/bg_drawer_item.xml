<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/accent_primary_dim" />
                    <corners android:radius="14dp" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/surface_outline_strong" />
                </shape>
            </item>
            <item
                android:width="3dp"
                android:gravity="start|center_vertical"
                android:left="8dp"
                android:top="10dp"
                android:bottom="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/accent_primary_strong" />
                    <corners android:radius="2dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1CF4F7FB" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/transparent" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
